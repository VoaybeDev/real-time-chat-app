Context } from 'react';\nimport './Toast.css';\n\nconst ToastContext = createContext();\n\nexport const ToastProvider = ({ children }) => {\n  const [toasts, setToasts] = useState([]);\n\n  const showToast = useCallback(({ title, message, type = 'info', duration = 4000 }) => {\n    const id = Date.now();\n    setToasts((prev) => [...prev, { id, title, message, type }]);\n\n    setTimeout(() => {\n      setToasts((prev) => prev.filter((t) => t.id !== id));\n    }, duration);\n  }, []);\n\n  const removeToast = useCallback((id) => {\n    setToasts((prev) => prev.filter((t) => t.id !== id));\n  }, []);\n\n  return (\n    <ToastContext.Provider value={{ showToast }}>\n      {children}\n      <div className=\"toast-container\">\n        {toasts.map((t) => (\n          <div key={t.id} className={`toast toast-${t.type}`}>\n            <div className=\"toast-icon\">\n              {t.type === 'success' && '✅'}\n              {t.type === 'error'   && '❌'}\n              {t.type === 'warning' && '⚠️'}\n              {t.type === 'info'    && 'ℹ️'}\n              {t.type === 'call'    && '📞'}\n            </div>\n\n            <div className=\"toast-content\">\n              {t.title   && <strong className=\"toast-title\">{t.title}</strong>}\n              {t.message && <span className=\"toast-message\">{t.message}</span>}\n            </div>\n\n            <button className=\"toast-close\" onClick={() => removeToast(t.id)}>✕</button>\n          </div>\n        ))}\n      </div>\n    </ToastContext.Provider>\n  );\n};\n\nexport const useToast = () => useContext(ToastContext);"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,WAAW,CAAEC,aAAa,CAAEC,UAAU,KAAQ,OAAO,CACxE,MAAO,aAAa,CAAC,OAAAC,IAAA,IAAAC,KAAA,CAAAC,GAAA,IAAAC,IAAA,yBAErB,KAAM,CAAAC,YAAY,cAAGN,aAAa,CAAC,CAAC,CAEpC,MAAO,MAAM,CAAAO,aAAa,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACxC,KAAM,CAACE,MAAM,CAAEC,SAAS,CAAC,CAAGb,QAAQ,CAAC,EAAE,CAAC,CAExC,KAAM,CAAAc,SAAS,CAAGb,WAAW,CAACc,KAAA,EAAwD,IAAvD,CAAEC,KAAK,CAAEC,OAAO,CAAEC,IA